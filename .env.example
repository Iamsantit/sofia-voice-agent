# ===========================================
# Agente de Voz Sofia - Environment Variables
# ===========================================
# Copia este archivo como .env y llena con tus credenciales reales
# cp .env.example .env

# --- Retell AI (Agente de Voz) ---
RETELL_API_KEY=

# --- Twilio (Telefonía) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Modal (Hosting) ---
# Modal usa autenticación vía CLI: `modal token new`
# Solo necesitas estos si corres en CI/CD:
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# --- Notion (CRM) ---
NOTION_API_KEY=
NOTION_PROPIEDADES_DB_ID=
NOTION_LEADS_DB_ID=
NOTION_LLAMADAS_DB_ID=

# --- Cal.com (Citas) ---
CAL_API_KEY=

# --- Anthropic (Resúmenes post-llamada) ---
ANTHROPIC_API_KEY=
